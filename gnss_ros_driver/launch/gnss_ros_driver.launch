<launch>
  <arg name="port" default="/dev/ttyUSB0" />
  <arg name="baudrate" default="115200" />
  <arg name="frame_id" default="gnss_ant" />
  <arg name="topic" default="/fix" />
  <arg name="covariance_mode" default="diagonal" />
  <arg name="max_match_time_diff_sec" default="0.02" />
  <arg name="cache_timeout_sec" default="1.0" />
  <arg name="publish_unmatched_gga" default="false" />
  <arg name="publish_invalid" default="false" />

  <node pkg="gnss_ros_driver" type="gnss_ros_driver" name="um982_nmea_navsatfix_node" output="screen">
    <param name="port" value="$(arg port)" />
    <param name="baudrate" value="$(arg baudrate)" />
    <param name="frame_id" value="$(arg frame_id)" />
    <param name="topic" value="$(arg topic)" />
    <param name="covariance_mode" value="$(arg covariance_mode)" />
    <param name="max_match_time_diff_sec" value="$(arg max_match_time_diff_sec)" />
    <param name="cache_timeout_sec" value="$(arg cache_timeout_sec)" />
    <param name="publish_unmatched_gga" value="$(arg publish_unmatched_gga)" />
    <param name="publish_invalid" value="$(arg publish_invalid)" />
  </node>
</launch>
